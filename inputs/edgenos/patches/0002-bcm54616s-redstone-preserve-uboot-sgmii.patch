diff --git a/drivers/net/phy/broadcom.c b/drivers/net/phy/broadcom.c
--- a/drivers/net/phy/broadcom.c
+++ b/drivers/net/phy/broadcom.c
@@ -27,6 +27,13 @@
 MODULE_AUTHOR("Maciej W. Rozycki");
 MODULE_LICENSE("GPL");
 
+static bool bcm54616s_redstone_preserve_uboot_sgmii(struct phy_device *phydev)
+{
+	return phydev->mdio.dev.of_node &&
+	       of_property_read_bool(phydev->mdio.dev.of_node,
+				     "brcm,redstone-preserve-uboot-sgmii");
+}
+
 static int bcm54xx_config_clock_delay(struct phy_device *phydev)
 {
 	int rc, val;
@@ -108,6 +115,12 @@ static int bcm54616s_config_init(struct phy_device *phydev)
 {
 	int rc, val;
 
+	if (bcm54616s_redstone_preserve_uboot_sgmii(phydev)) {
+		phydev_info(phydev,
+			    "Redstone: preserving U-Boot BCM54616S SGMII/SerDes state\n");
+		return 0;
+	}
+
 	if (phydev->interface != PHY_INTERFACE_MODE_SGMII &&
 	    phydev->interface != PHY_INTERFACE_MODE_1000BASEX)
 		return 0;
@@ -590,6 +603,12 @@ static int bcm54616s_config_aneg(struct phy_device *phydev)
 {
 	int ret;
 
+	if (bcm54616s_redstone_preserve_uboot_sgmii(phydev)) {
+		phydev_info(phydev,
+			    "Redstone: skipping BCM54616S autoneg setup for preserved SGMII state\n");
+		return 0;
+	}
+
 	/* Aneg firstly. */
 	if (phydev->dev_flags & PHY_BCM_FLAGS_MODE_1000BX)
 		ret = genphy_c37_config_aneg(phydev);
