# Phase 1 baseline: stock ImmortalWrt 24.10.6 freescale_p2020rdb,
# minimum packages, initramfs FIT image for U-Boot tftp + bootm.
# Goal: test if 6.6 mainline kernel boots on Redstone hardware
#       (PCIe panic / eth1 BCM54616S issues may already be fixed upstream).

CONFIG_TARGET_mpc85xx=y
CONFIG_TARGET_mpc85xx_p2020=y
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_mpc85xx_p2020_DEVICE_freescale_p2020rdb=y

# initramfs FIT image (no NAND write needed)
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# Minimum debug-friendly packages for bring-up
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-fsl-pq-mdio=y
CONFIG_PACKAGE_kmod-gianfar=y
CONFIG_PACKAGE_kmod-broadcom-phy=y
CONFIG_PACKAGE_ip-tiny=y
CONFIG_PACKAGE_iproute2-tiny=y
CONFIG_PACKAGE_strace=y
CONFIG_PACKAGE_lspci=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_kmod-tun=y
