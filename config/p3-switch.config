# Redstone switch package set (P3)
# Appended to OpenWrt 22.03 mpc85xx_p2020 .config by scripts/diy-script.sh
# All as built-in (=y) so they land in the initramfs.
#
# Ordering loosely matches roadmap roles. Each section can be commented out
# without breaking the others. See README.md for size impact.

# --- L3 routing (FRRouting) -----------------------------------------------
CONFIG_PACKAGE_frr=y
CONFIG_PACKAGE_frr-bgpd=y
CONFIG_PACKAGE_frr-ospfd=y
CONFIG_PACKAGE_frr-ospf6d=y
CONFIG_PACKAGE_frr-staticd=y
CONFIG_PACKAGE_frr-zebra=y
CONFIG_PACKAGE_frr-watchfrr=y
CONFIG_PACKAGE_frr-vtysh=y
CONFIG_PACKAGE_frr-libfrr=y

# --- L3 routing (BIRD2 — alternative; useful for IXP-style BGP) -----------
CONFIG_PACKAGE_bird2=y
CONFIG_PACKAGE_bird2c=y

# --- L2 (STP/RSTP, multicast) ---------------------------------------------
CONFIG_PACKAGE_mstpd=y
CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-llc=y
CONFIG_PACKAGE_kmod-stp=y
CONFIG_PACKAGE_igmpproxy=y

# --- Discovery / Mgmt -----------------------------------------------------
CONFIG_PACKAGE_lldpd=y
CONFIG_PACKAGE_snmpd=y
CONFIG_PACKAGE_snmp-utils=y

# --- Time -----------------------------------------------------------------
CONFIG_PACKAGE_chrony=y
CONFIG_PACKAGE_chrony-nts=y

# --- Diagnostics ----------------------------------------------------------
CONFIG_PACKAGE_tcpdump-mini=y
CONFIG_PACKAGE_ethtool-full=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_iputils-tracepath=y

# --- Operator UX ----------------------------------------------------------
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ip-full=y

# --- Update / sysupgrade --------------------------------------------------
CONFIG_PACKAGE_attendedsysupgrade-common=y
CONFIG_PACKAGE_auc=y

# --- Telemetry (collectd → SNMP/Prometheus pipeline ready) ----------------
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-uptime=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-snmp=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-syslog=y
